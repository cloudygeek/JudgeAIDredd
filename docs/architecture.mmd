%%{ init: { 'theme': 'base', 'themeVariables': { 'primaryColor': '#2E86AB', 'primaryTextColor': '#fff', 'primaryBorderColor': '#1B6B8A', 'lineColor': '#666', 'secondaryColor': '#27AE60', 'tertiaryColor': '#F39C12', 'errorColor': '#E74C3C' } } }%%

flowchart TD
    subgraph Agent["🤖 Claude Agent (SDK)"]
        A1[Receive Task]
        A2[Plan & Reason]
        A3[Request Tool Call]
        A4[Receive Result]
        A5[Produce Response]
    end

    subgraph Hooks["🔒 Judge AI Dredd Hook Chain"]
        direction TB

        subgraph H1["UserPromptSubmit"]
            UPS1{First prompt?}
            UPS2[Store as<br/>ORIGINAL INTENT<br/>+ compute embedding]
            UPS3[Store as<br/>TURN INTENT]
            UPS4{Drift from<br/>original?}
            UPS5["< 0.2: ON-TASK<br/>No action"]
            UPS6["0.2-0.3: SCOPE CREEP<br/>Inject reminder"]
            UPS7["0.3-0.5: DRIFTING<br/>Inject warning"]
            UPS8["≥ 0.5: HIJACKED<br/>Inject security alert"]
        end

        subgraph H2["PreToolUse — Three-Stage Pipeline"]
            direction TB
            S1["Stage 1: Policy Engine<br/>(instant)"]
            S1A["ALLOW<br/>Read, Glob, Grep,<br/>safe Bash"]
            S1D["DENY<br/>rm -rf, printenv,<br/>curl @file, force push"]
            S1R["REVIEW<br/>.env reads, curl,<br/>&&, eval, MCP tools"]

            S2["Stage 2: Embedding Drift<br/>(~50ms via Ollama)"]
            S2A["sim ≥ 0.6 → ALLOW"]
            S2D["sim < 0.4 → DENY"]
            S2R["0.4-0.6 → Stage 3"]

            S3["Stage 3: LLM Judge<br/>(~1.4s Bedrock / ~12s Ollama)"]
            S3C["consistent → ALLOW"]
            S3H["drifting/hijacked → DENY"]
            S3F["+ File Context<br/>Assembled content of<br/>all files written<br/>this session"]
        end

        subgraph H3["PostToolUse"]
            PT1[Record file reads<br/>Track sensitive files]
            PT2[Record file writes<br/>Accumulate content<br/>Detect multi-write]
            PT3[Record env var<br/>mutations]
            PT4[Detect canary<br/>cross-contamination]
        end

        subgraph H4["Stop"]
            ST1[Write session log<br/>to results/]
            ST2[Log turn metrics<br/>& classifications]
            ST3[Clean up session]
        end
    end

    subgraph State["📊 Session Tracker"]
        SS1[Original Intent<br/>+ Embedding]
        SS2[Turn Intent History<br/>+ Drift per turn]
        SS3[Tool Call History<br/>+ Decisions]
        SS4[File Content Map<br/>Accumulated writes]
        SS5[Env Var Registry]
        SS6[Turn Metrics<br/>Classification per turn]
    end

    subgraph Models["🧠 Judge Models"]
        EM["Embedding Model<br/>nomic-embed-text<br/>(Ollama, ~15ms)"]
        JM["Judge LLM<br/>nemotron-3-super"]
        JM1["Local: Ollama<br/>~12s per call<br/>Free"]
        JM2["Cloud: Bedrock<br/>~1.4s per call<br/>Per-token cost"]
    end

    %% Agent flow
    A1 -->|prompt| H1
    UPS1 -->|Yes| UPS2
    UPS1 -->|No| UPS3
    UPS3 --> UPS4
    UPS4 --> UPS5
    UPS4 --> UPS6
    UPS4 --> UPS7
    UPS4 --> UPS8
    UPS2 --> A2
    UPS5 --> A2
    UPS6 -->|systemMessage| A2
    UPS7 -->|systemMessage| A2
    UPS8 -->|systemMessage| A2

    A2 --> A3
    A3 -->|tool_name, tool_input| H2

    %% PreToolUse pipeline
    S1 --> S1A
    S1 --> S1D
    S1 --> S1R
    S1R --> S2
    S2 --> S2A
    S2 --> S2D
    S2 --> S2R
    S2R --> S3
    S3 --> S3C
    S3 --> S3H
    S3F -.->|file context<br/>for Bash/git| S3

    S1A -->|allow| A4
    S2A -->|allow| A4
    S3C -->|allow| A4
    S1D -->|deny + reason| A2
    S2D -->|deny + reason| A2
    S3H -->|deny + reason| A2

    %% PostToolUse
    A4 --> H3
    PT1 --> SS4
    PT2 --> SS4
    PT3 --> SS5
    PT4 --> SS4
    H3 --> A2

    %% When agent finishes
    A5 --> H4
    ST1 --> SS6

    %% State connections
    UPS2 --> SS1
    UPS3 --> SS2
    SS1 -.-> S2
    SS4 -.-> S3F
    S1 -.->|decision| SS3
    S2 -.->|decision| SS3
    S3 -.->|decision| SS3

    %% Model connections
    EM -.-> S2
    JM -.-> S3
    JM --- JM1
    JM --- JM2

    %% Styling
    style S1A fill:#27AE60,color:#fff
    style S2A fill:#27AE60,color:#fff
    style S3C fill:#27AE60,color:#fff
    style S1D fill:#E74C3C,color:#fff
    style S2D fill:#E74C3C,color:#fff
    style S3H fill:#E74C3C,color:#fff
    style S1R fill:#F39C12,color:#fff
    style S2R fill:#F39C12,color:#fff
    style UPS5 fill:#27AE60,color:#fff
    style UPS6 fill:#F39C12,color:#fff
    style UPS7 fill:#E74C3C,color:#fff
    style UPS8 fill:#E74C3C,color:#fff
