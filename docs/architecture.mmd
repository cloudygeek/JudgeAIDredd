flowchart TD
    START([Agent receives task]) --> UPS

    subgraph UPS["1. UserPromptSubmit Hook"]
        direction LR
        U1[Capture prompt] --> U2{First prompt?}
        U2 -->|Yes| U3[Store as<br/>ORIGINAL INTENT<br/>+ embedding]
        U2 -->|No| U4[Compute drift<br/>from original]
        U4 --> U5{Drift level?}
        U5 -->|"< 0.2"| U6[ON-TASK<br/>No action]:::green
        U5 -->|"0.2 - 0.3"| U7[SCOPE CREEP<br/>Remind agent]:::amber
        U5 -->|"0.3 - 0.5"| U8[DRIFTING<br/>Warn agent]:::red
        U5 -->|"> 0.5"| U9[HIJACKED<br/>Security alert]:::darkred
    end

    UPS --> AGENT[Agent reasons & requests tool call]

    AGENT --> PTU

    subgraph PTU["2. PreToolUse Hook — Three-Stage Pipeline"]
        direction TB
        P1["Stage 1: Policy Engine"]:::blue --> P1D{Decision?}
        P1D -->|ALLOW<br/>Read, Glob, Grep,<br/>ls, git status| ALLOW1[✓ Execute tool]:::green
        P1D -->|DENY<br/>rm -rf, printenv,<br/>curl @file| DENY1[✗ Block tool]:::red
        P1D -->|REVIEW<br/>.env, curl, &&,<br/>MCP tools| P2

        P2["Stage 2: Embedding Drift<br/>~50ms via Ollama"]:::blue --> P2D{Similarity?}
        P2D -->|"> 0.6"| ALLOW2[✓ Execute tool]:::green
        P2D -->|"< 0.4"| DENY2[✗ Block tool]:::red
        P2D -->|"0.4 - 0.6"| P3

        P3["Stage 3: LLM Judge<br/>~1.4s Bedrock / ~12s local"]:::blue --> P3D{Verdict?}
        P3D -->|consistent| ALLOW3[✓ Execute tool]:::green
        P3D -->|drifting /<br/>hijacked| DENY3[✗ Block tool]:::red

        FC["📁 File Context<br/>Assembled content of<br/>all files written<br/>this session"] -.->|"injected for<br/>Bash & git commands"| P3
    end

    ALLOW1 & ALLOW2 & ALLOW3 --> EXEC[Tool executes]
    DENY1 & DENY2 & DENY3 --> BLOCKED[Agent receives rejection<br/>& tries different approach]
    BLOCKED --> AGENT

    EXEC --> POST

    subgraph POST["3. PostToolUse Hook — State Tracking"]
        direction LR
        T1["📄 Track file<br/>reads & writes"] ~~~ T2["🔑 Track env<br/>var mutations"] ~~~ T3["⚠️ Detect canary<br/>cross-contamination"]
    end

    POST --> STATE

    subgraph STATE["Session State"]
        direction LR
        S1["Original intent<br/>+ embedding"] ~~~ S2["Turn-by-turn<br/>intent history"] ~~~ S3["File content<br/>map"] ~~~ S4["Tool call<br/>decisions"]
    end

    STATE -.-> UPS
    STATE -.-> FC
    POST -->|"Agent continues<br/>reasoning"| AGENT

    AGENT -->|"No more tool calls"| STOP

    subgraph STOP["4. Stop Hook"]
        direction LR
        L1["Write session log"] ~~~ L2["Per-turn metrics<br/>& classifications"] ~~~ L3["Clean up"]
    end

    STOP --> FIN([Session complete])

    subgraph MODELS["Judge Models"]
        direction LR
        M1["🔤 Embeddings<br/>nomic-embed-text<br/>Ollama · ~15ms"]
        M2["🧠 Judge LLM<br/>nemotron-3-super<br/>Bedrock ~1.4s<br/>Ollama ~12s"]
    end

    M1 -.-> P2
    M2 -.-> P3

    classDef green fill:#D4EDDA,stroke:#28A745,color:#155724
    classDef amber fill:#FFF3CD,stroke:#FFC107,color:#856404
    classDef red fill:#F8D7DA,stroke:#DC3545,color:#721C24
    classDef darkred fill:#DC3545,stroke:#A71D2A,color:#FFFFFF
    classDef blue fill:#D6EAF8,stroke:#2E86AB,color:#1B4F72
