{
  "family": "judge-ai-dredd-test7",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/judge-ai-dredd-task-role",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/judge-ai-dredd-execution-role",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "containerDefinitions": [
    {
      "name": "test7",
      "image": "<ACCOUNT_ID>.dkr.ecr.eu-west-2.amazonaws.com/judge-ai-dredd-test7:latest",
      "essential": true,
      "environment": [
        { "name": "AWS_REGION",      "value": "eu-west-2" },
        { "name": "S3_REGION",       "value": "eu-west-1" },
        { "name": "S3_BUCKET",       "value": "cko-results" },
        { "name": "S3_PREFIX",       "value": "test7" },
        { "name": "TEST7_MODELS",    "value": "claude-haiku-4-5,claude-sonnet-4-6,claude-opus-4-6" },
        { "name": "TEST7_SCENARIOS", "value": "intermediate,sophisticated" },
        { "name": "TEST7_DEFENCES",  "value": "none,intent-tracker" },
        { "name": "TEST7_REPS",      "value": "20" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/judge-ai-dredd/test7",
          "awslogs-region": "eu-west-2",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "mountPoints": [],
      "portMappings": []
    }
  ]
}
