{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SecretsManagerAnthropicKey",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue"
      ],
      "Resource": [
        "arn:aws:secretsmanager:eu-west-2:<ACCOUNT_ID>:secret:judge-ai-dredd/anthropic-api-key*"
      ]
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:eu-west-2:<ACCOUNT_ID>:log-group:/ecs/judge-ai-dredd*"
    }
  ]
}
