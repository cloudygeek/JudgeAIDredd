# Judge AI Dredd — HOOK role (AI Sandbox zip layout)
#
# Used by the CodeBuild pipeline for the hook-role Fargate service.
# Flat zip: Dockerfile, docker-entrypoint.sh, package.json, src/ all at
# the build context root. Mirrors Dockerfile.dashboard-zip exactly except
# for the entrypoint shipped — DREDD_ROLE defaults to "hook" here.
#
# AWS CLI is NOT installed: Bedrock + DynamoDB calls go through the SDK.

FROM 891377407345.dkr.ecr.eu-west-1.amazonaws.com/cko-pull-through/docker-hub/library/node:22-bookworm-slim

WORKDIR /app

# Minimal runtime deps. No awscli — the app uses @aws-sdk directly.
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# ── Node dependencies ───────────────────────────────────────────────────────
COPY package.json package-lock.json ./
RUN npm install --registry https://registry.npmjs.org

# ── Application source (server + dashboard only) ───────────────────────────
COPY tsconfig.json ./
COPY src/ ./src/

# ── Hook script (served by /api/integration-bundle for Claude Code users) ──
COPY hooks/ ./hooks/

# ── Build provenance ────────────────────────────────────────────────────────
ARG GIT_COMMIT=unknown
ARG GIT_DIRTY=false
ENV GIT_COMMIT=${GIT_COMMIT}
ENV GIT_DIRTY=${GIT_DIRTY}

# ── Data volume mount point ─────────────────────────────────────────────────
RUN mkdir -p /data/sessions /data/logs

# ── Entrypoint (hook-role default) ─────────────────────────────────────────
COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

# ── Non-root user ───────────────────────────────────────────────────────────
RUN useradd -m -s /bin/bash dredd \
    && chown -R dredd:dredd /app /data
USER dredd

EXPOSE 3000

ENTRYPOINT ["/docker-entrypoint.sh"]
