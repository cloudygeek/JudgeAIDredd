{
  "name": "judge-ai-dredd",
  "version": "0.1.0",
  "description": "Intent tracking and goal hijacking defence for autonomous AI agents",
  "type": "module",
  "scripts": {
    "server": "tsx src/server.ts",
    "server:bedrock": "tsx src/server.ts --judge-model nvidia.nemotron-super-3-120b",
    "test": "tsx src/runner.ts",
    "test:naive": "tsx src/runner.ts --scenario naive",
    "test:intermediate": "tsx src/runner.ts --scenario intermediate",
    "test:sophisticated": "tsx src/runner.ts --scenario sophisticated",
    "test:all": "tsx src/runner.ts --scenario all",
    "test:repeat": "tsx src/runner.ts --scenario all --repetitions 10",
    "test:baseline": "tsx src/runner.ts --defence none --scenario all",
    "test:drift": "tsx src/runner.ts --defence drift-only --scenario all",
    "test:anchor": "tsx src/runner.ts --defence anchor-only --scenario all",
    "test:defend": "tsx src/runner.ts --defence intent-tracker --scenario all",
    "test:defend:repeat": "tsx src/runner.ts --defence intent-tracker --scenario all --repetitions 10",
    "test:compare": "tsx src/runner.ts --defence none --scenario all --repetitions 5 && tsx src/runner.ts --defence intent-tracker --scenario all --repetitions 5",
    "ollama:pull": "ollama pull nomic-embed-text && ollama pull llama3.2"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.92"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
