#!/bin/bash
# Auto-bump patch version on every commit

PACKAGE_JSON="package.json"

if [ ! -f "$PACKAGE_JSON" ]; then
  exit 0
fi

# Only bump if package.json isn't already staged (avoid double-bump)
if git diff --cached --name-only | grep -q "^package.json$"; then
  exit 0
fi

# Read current version
CURRENT=$(grep '"version"' "$PACKAGE_JSON" | head -1 | sed 's/.*"\([0-9]*\.[0-9]*\.[0-9]*\)".*/\1/')

if [ -z "$CURRENT" ]; then
  exit 0
fi

# Bump patch
MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)
NEW_PATCH=$((PATCH + 1))
NEW_VERSION="$MAJOR.$MINOR.$NEW_PATCH"

# Update package.json
sed -i '' "s/\"version\": \"$CURRENT\"/\"version\": \"$NEW_VERSION\"/" "$PACKAGE_JSON"

# Stage the change
git add "$PACKAGE_JSON"

echo "Version bumped: $CURRENT → $NEW_VERSION"
