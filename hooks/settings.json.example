{
  "hooks": {
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "/path/to/JudgeAIDredd/hooks/dredd-hook.sh", "timeout": 30 }] }
    ],
    "PreToolUse": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "/path/to/JudgeAIDredd/hooks/dredd-hook.sh", "timeout": 60 }] }
    ],
    "PostToolUse": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "/path/to/JudgeAIDredd/hooks/dredd-hook.sh", "timeout": 10 }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "/path/to/JudgeAIDredd/hooks/dredd-hook.sh", "timeout": 10 }] }
    ],
    "SessionEnd": [
      { "hooks": [{ "type": "command", "command": "/path/to/JudgeAIDredd/hooks/dredd-hook.sh", "timeout": 10 }] }
    ],
    "PreCompact": [
      { "hooks": [{ "type": "command", "command": "/path/to/JudgeAIDredd/hooks/dredd-hook.sh", "timeout": 5 }] }
    ]
  }
}
