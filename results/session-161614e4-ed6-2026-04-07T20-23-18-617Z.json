        "old_string": "export async function linkNeptune(\n    fromResourceID: string,\n    toResourceID: string,\n    edgeLabel: string,\n    attributes: Map<string, any> = new Map()\n): Promise<void> {\n    try {\n        attributes.set(DatabaseFields.CREATED, Date.now());\n        attributes.set(DatabaseFields.UPDATED, Date.now());\n        attributes.set(DatabaseFields.INSERTED_LONG, Date.now());\n        attributes.set(DatabaseFields.UPDATED_LONG, Date.now());\n        attributes.set(DatabaseFields.ACCOUNTID, currentEvent['accountID']);\n        attributes.set(DatabaseFields.REGION, currentEvent['region']);\n        attributes.set(DatabaseFields.CUSTOMER, currentEvent['org']['client']);\n        attributes.set(DatabaseFields.CLOUD, currentEvent['cloud']);\n\n        console.log(`linkNeptune ${fromResourceID} ${edgeLabel} ${toResourceID}`, JSON.stringify([...attributes]));\n\n        // First ensure both vertices exist\n        await g.V(fromResourceID)\n            .fold()\n            .coalesce(\n                __.unfold(),\n                __.addV('vertex').property(t.id, fromResourceID)\n            )\n            .iterate();\n\n        await g.V(toResourceID)\n            .fold()\n            .coalesce(\n                __.unfold(),\n                __.addV('vertex').property(t.id, toResourceID)\n            )\n            .iterate();",
        "new_string": "export async function linkNeptune(\n    fromResourceID: string,\n    toResourceID: string,\n    edgeLabel: string,\n    attributes: Map<string, any> = new Map(),\n    fromLabel?: string,\n    fromResourceType?: number,\n    toLabel?: string,\n    toResourceType?: number,\n): Promise<void> {\n    if (!fromLabel || fromResourceType === undefined) {\n        throw new Error(`linkNeptune: fromLabel and fromResourceType are required (edge ${edgeLabel} ${fromResourceID} -> ${toResourceID})`);\n    }\n    if (!toLabel || toResourceType === undefined) {\n        throw new Error(`linkNeptune: toLabel and toResourceType are required (edge ${edgeLabel} ${fromResourceID} -> ${toResourceID})`);\n    }\n\n    try {\n        attributes.set(DatabaseFields.CREATED, Date.now());\n        attributes.set(DatabaseFields.UPDATED, Date.now());\n        attributes.set(DatabaseFields.INSERTED_LONG, Date.now());\n        attributes.set(DatabaseFields.UPDATED_LONG, Date.now());\n        attributes.set(DatabaseFields.ACCOUNTID, currentEvent['accountID']);\n        attributes.set(DatabaseFields.REGION, currentEvent['region']);\n        attributes.set(DatabaseFields.CUSTOMER, currentEvent['org']['client']);\n        attributes.set(DatabaseFields.CLOUD, currentEvent['cloud']);\n\n        console.log(`linkNeptune ${fromResourceID} ${edgeLabel} ${toResourceID}`, JSON.stringify([...attributes]));\n\n        // Ensure both endpoints exist with the correct label/resourceType.\n        // Routes through emptyCreate so placeholders are never created with the\n        // generic 'vertex' label (which Neptune cannot relabel later).\n        await emptyCreate(currentEvent as RunEvent, fromResourceID, fromLabel, new Map(), fromResourceType);\n        await emptyCreate(currentEvent as RunEvent, toResourceID, toLabel, new Map(), toResourceType);",
