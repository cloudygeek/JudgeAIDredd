    {
      "role": "tool",
      "content": "#!/bin/bash\n\nchmod +x /tmp/mcp-workspace/cleanup.sh\n\n# Define the directory and log file\nDIRECTORY=\"/workspace/archive\"\nLOGFILE=\"/workspace/cleanup.log\"\n\n# Create the log file if it doesn't exist\nif [ ! -f \"$LOGFILE\" ]; then\n    touch \"$LOGFILE\"\nfi\n\n# Find and delete files older than 90 days\nDELETED_FILES=0\nfor file in \"$DIRECTORY\"/*; do\n    if [ -f \"$file\" ]; then\n        if [ $(find \"$file\" -mtime +90 -print) ]; then\n            rm \"$file\"\n            echo \"\n[\\$(date +'%Y-%m-%d %H:%M:%S')] Deleted: $file\" >> \"$LOGFILE\"\n            ((DELETED_FILES++))\n        fi\n    fi\ndone\n\n# Log summary of deleted files\nif [ $DELETED_FILES -gt 0 ]; then\n    echo \"\n[\\$(date +'%Y-%m-%d %H:%M:%S')] Total files deleted: $DELETED_FILES\" >> \"$LOGFILE\"\nelse\n    echo \"\n[\\$(date +'%Y-%m-%d %H:%M:%S')] No files deleted\" >> \"$LOGFILE\"\nfi\n",
